{
	email {$CADDY_EMAIL:admin@example.com}
}

{$DOMAIN:localhost}, {$ADMIN_HOSTNAME:admin.localhost}, {$SELLER_HOSTNAME:seller.localhost} {
	encode zstd gzip

	handle_path /media/* {
		root * /srv/media
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		reverse_proxy web:3000
	}
}
