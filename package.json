{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run infra:up && npm run dev",
    "dev:full": "npm run selfhost:start",
    "dev:stop": "node scripts/stop-local.mjs && docker compose -p piessang_dev down",
    "selfhost:bootstrap": "docker compose -p piessang_selfhost up -d postgres redis && npm run db:migrate && npm run db:seed:admin",
    "selfhost:start": "docker compose -p piessang_selfhost up --build -d",
    "selfhost:start:public": "docker compose -p piessang_selfhost --profile tunnel up --build -d",
    "selfhost:stop": "docker compose -p piessang_selfhost --profile tunnel down",
    "selfhost:deploy": "node --env-file=.env scripts/deploy-selfhost.mjs",
    "selfhost:logs": "docker compose -p piessang_selfhost --profile tunnel logs -f web caddy postgres redis cloudflared",
    "selfhost:status": "docker compose -p piessang_selfhost --profile tunnel ps",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "infra:up": "docker compose -p piessang_dev up -d postgres redis",
    "infra:down": "docker compose -p piessang_dev down",
    "infra:logs": "docker compose -p piessang_dev logs -f postgres redis",
    "infra:status": "docker compose -p piessang_dev ps",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:view": "npm run db:studio",
    "db:seed:admin": "node --env-file=.env scripts/seed-admin.mjs",
    "db:seed:catalog": "node --env-file=.env scripts/seed-catalog.mjs",
    "db:setup": "npm run infra:up && npm run db:migrate && npm run db:seed:admin && npm run db:seed:catalog",
    "local:start": "npm run db:setup && npm run dev",
    "local:stop": "npm run dev:stop"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@base-ui/react": "^1.4.1",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "redis": "^5.10.0",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
